# Copy this file to .env and fill in your own values
# Never commit your actual .env file to GitHub

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Local SQLite (default). Replace with your PostgreSQL URL for production.
# Example: postgresql://username:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# API key required by monitoring officer to get a scoped token
# Can be any random string — keep it secret in production
MONITORING_API_KEY=your-monitoring-api-key-here
